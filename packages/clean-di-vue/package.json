{
  "name": "clean-di-vue",
  "version": "0.1.0",
  "description": "Vue 3 integration for clean-di: DiProvider, composables (useBean/useExpose), and createConnector.",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./mobx": {
      "types": "./dist/mobx.d.ts",
      "import": "./dist/mobx.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -b",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src"
  },
  "peerDependencies": {
    "clean-di": ">=1.0.0",
    "vue": ">=3.3.0"
  },
  "peerDependenciesMeta": {
    "mobx-vue-lite": {
      "optional": true
    }
  },
  "devDependencies": {
    "@testing-library/vue": "^8.0.0",
    "@vitejs/plugin-vue": "^5.0.0",
    "clean-di": "workspace:*",
    "jsdom": "^25.0.0",
    "mobx": "^6.13.7",
    "mobx-vue-lite": "^0.2.0",
    "vue": "^3.4.0",
    "vite": "^6.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20"
  }
}
