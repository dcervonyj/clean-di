{
  "name": "clean-di-codegen",
  "version": "1.0.0",
  "description": "Build-time codegen CLI for clean-di. Reads .di.ts files and emits .di.generated.ts wiring.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "clean-di-codegen": "./dist/bin.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./vite": {
      "types": "./dist/plugins/vite.d.ts",
      "import": "./dist/plugins/vite.js"
    },
    "./rollup": {
      "types": "./dist/plugins/rollup.d.ts",
      "import": "./dist/plugins/rollup.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -b",
    "check:examples": "node dist/bin.js --check",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src"
  },
  "dependencies": {
    "chokidar": "^4.0.0",
    "picocolors": "^1.0.0",
    "mri": "^1.2.0",
    "jiti": "^2.0.0"
  },
  "peerDependencies": {
    "typescript": ">=5.0.0",
    "vite": ">=5.0.0",
    "rollup": ">=4.0.0"
  },
  "peerDependenciesMeta": {
    "typescript": {
      "optional": false
    },
    "vite": {
      "optional": true
    },
    "rollup": {
      "optional": true
    }
  },
  "devDependencies": {
    "clean-di": "workspace:*",
    "@types/node": "^20.0.0",
    "rollup": "^4.0.0",
    "vite": "^5.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/clean-di/clean-di.git"
  },
  "keywords": [
    "dependency-injection",
    "di",
    "codegen",
    "typescript",
    "cli"
  ]
}
