{
  "name": "clean-di-svelte",
  "version": "0.1.0",
  "description": "Svelte 5 integration for clean-di: DiProvider, getExpose/getBean, and createConnector.",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./DiProvider.svelte": "./dist/DiProvider.svelte"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -b && cp src/DiProvider.svelte dist/DiProvider.svelte",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src"
  },
  "peerDependencies": {
    "clean-di": ">=1.0.0",
    "svelte": ">=5.0.0"
  },
  "devDependencies": {
    "@testing-library/svelte": "^5.0.0",
    "@sveltejs/vite-plugin-svelte": "^4.0.0",
    "clean-di": "workspace:*",
    "jsdom": "^25.0.0",
    "svelte": "^5.0.0",
    "vite": "^6.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20"
  }
}
