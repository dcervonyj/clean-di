{
  "name": "clean-di-example-modular",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -b",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "start": "node dist/index.js",
    "codegen": "clean-di-codegen",
    "check:codegen": "clean-di-codegen --check"
  },
  "dependencies": {
    "clean-di": "workspace:*"
  },
  "devDependencies": {
    "clean-di-codegen": "workspace:*",
    "typescript": ">=5.0.0"
  },
  "cleanDi": {
    "include": ["src/**/*.di.ts"],
    "exclude": ["**/node_modules/**"]
  }
}
